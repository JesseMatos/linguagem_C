#include <stdio.h>

int main()
{
    int opcao;
    
    printf("Escolha o setor desejado (1-5): ");
    scanf("%d", &opcao);
    
    switch(opcao) {
        case 1:
            printf("Emergência = 24h");
            break;
        case 2:
            printf("Exames = 08h às 12h");
            break;
        case 3:
            printf("Consultas = 08h às 17h");
            break;
        case 4:
            printf("Vacinação = 14h às 18h");
            break;
        case 5:
            printf("Farmácia = 05h às 17h");
            break;
        default:
            printf("Setor inválido");
    }

    return 0;
}
