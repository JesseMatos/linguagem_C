#include <stdio.h>

int main() {
    float num1, num2;
    char op;
    
    printf("Digite dois números: \n");
    scanf("%f %f", &num1, &num2);
    
    printf("Escolha a operação (+, -, *, /): ");
    scanf(" %c", &op);
    
    switch(op) {
        case'+': 
            printf("Resultado: %.3f\n", num1 + num2); 
            break;
        case'-': 
            printf("Resultado: %.3ff\n", num1 - num2); 
            break;
        case'*': 
            printf("Resultado: %.3f\n", num1 * num2); 
            break;
        case'/':
            if(num2 != 0) 
                printf("Resultado: %.3f\n", num1 / num2);
            else 
                printf("Erro: divisão por zero!\n");
            break;
        default: 
            printf("Operação inválida!\n");
    }
    
    return 0;
}
